---
import Layout from "../layouts/Layout.astro";
import Container from "../components/Container.astro";
import BackToPrevious from "../components/BackToPrevious.astro";
import TaskList from "../components/TaskList.astro";
import { getActiveTasks } from "../lib/tasks";

const activeTasks = await getActiveTasks();
---

<Layout title="Tasks" description="Active tasks from the second brain.">
	<Container size="md">
		<div class="animate">
			<BackToPrevious href="/">Home</BackToPrevious>
		</div>
		<div class="mt-5 animate" style="animation-delay: 100ms">
			<h1 class="text-2xl font-semibold text-black dark:text-white">
				Tasks
			</h1>
			<p class="mt-2 text-black/60 dark:text-white/60">
				{activeTasks.length} active tasks, sorted by urgency.
			</p>
		</div>

		<TaskList tasks={activeTasks} />
	</Container>
</Layout>
