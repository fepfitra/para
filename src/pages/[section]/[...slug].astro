---
import DocLayout from "../../layouts/DocLayout.astro";
import Container from "../../components/Container.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import BackToPrevious from "../../components/BackToPrevious.astro";
import {
	loadSections,
	listSection,
	fetchMarkdown,
} from "../../lib/s3";
import { renderMarkdownWithContext, extractTitle, extractToc, stripFrontmatter } from "../../lib/markdown";

const SECTIONS = await loadSections();
const { section, slug } = Astro.params;
const pageSlug = Array.isArray(slug) ? slug.join("/") : slug;

const sectionMeta = SECTIONS.find((s) => s.slug === section);
if (!sectionMeta) {
	return Astro.redirect("/");
}

const entries = await listSection(sectionMeta.prefix);
const entry = entries.find((e) => e.slug === pageSlug);

if (!entry) {
	return new Response("Not found", { status: 404 });
}

const raw = await fetchMarkdown(entry.key);
const body = stripFrontmatter(raw);
const rawHtml = await renderMarkdownWithContext(raw, entry.key);
const { html: htmlContent, toc } = extractToc(rawHtml);
const title = extractTitle(body) || entry.title;
const htmlContentWithoutH1 = htmlContent.replace(/<h1[^>]*>.*?<\/h1>/i, "");

const crumbs = entry.segments.slice(0, -1);
---

<DocLayout title={title} description={`${title} — ${sectionMeta.label}`}>
	<div class="flex flex-col gap-8 lg:flex-row" id="page-layout">
		<div class="min-w-0 flex-1">
			<Container size="xl">
			<article class="prose dark:prose-invert mx-auto" data-pagefind-body>
				<div class="animate mb-10">
					<BackToPrevious href={`/${sectionMeta.slug}`}>
						Back to {sectionMeta.label}
					</BackToPrevious>
				</div>

				{toc.length > 0 && (
					<div class="mb-8 lg:hidden">
						<TableOfContents headings={toc} open={false} />
					</div>
				)}

				<div class="animate mb-6">
					<div class="mb-2 flex flex-wrap items-center gap-1 text-xs text-black/40 dark:text-white/40 not-prose">
						<a href="/" class="no-underline hover:text-black dark:hover:text-white transition-colors">Home</a>
						<span>/</span>
						<a href={`/${sectionMeta.slug}`} class="no-underline hover:text-black dark:hover:text-white transition-colors">{sectionMeta.label}</a>
						{crumbs.map((seg) => (
							<Fragment>
								<span>/</span>
								<span>{seg}</span>
							</Fragment>
						))}
					</div>
					<div class="flex items-center justify-between gap-4">
						<h1 class="text-2xl font-semibold text-black dark:text-white">
							{title}
						</h1>
						<button
							id="copy-md-btn"
							class="shrink-0 cursor-pointer rounded-md border border-black/10 px-2 py-1 text-xs font-medium text-black/50 transition-colors hover:border-black/20 hover:text-black/70 dark:border-white/10 dark:text-white/50 dark:hover:border-white/20 dark:hover:text-white/70 not-prose"
							type="button"
							data-raw={body}
						>
							📋 Copy
						</button>
					</div>
				</div>

				<div class="animate mt-8" set:html={htmlContentWithoutH1} />
			</article>
			</Container>
		</div>

		{toc.length > 0 && (
			<aside class="hidden w-64 shrink-0 lg:block">
				<div class="sticky top-32 max-h-[calc(100vh-12rem)] overflow-y-auto">
					<TableOfContents headings={toc} />
				</div>
			</aside>
		)}
	</div>
</DocLayout>

<script>
	const copyBtn = document.getElementById('copy-md-btn');
	if (copyBtn) {
		copyBtn.addEventListener('click', async () => {
			const text = copyBtn.getAttribute('data-raw') || '';
			await navigator.clipboard.writeText(text);
			copyBtn.textContent = '✓ Copied';
			setTimeout(() => { copyBtn.textContent = '📋 Copy'; }, 2000);
		});
	}
</script>