---
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/Container.astro";
import BackToPrevious from "../../components/BackToPrevious.astro";
import SidebarItem from "../../components/SidebarItem.astro";
import {
	SECTIONS,
	listSection,
	buildTree,
	getPinnedFolders,
	getPinnedPaths,
} from "../../lib/s3";

const { section } = Astro.params;
const sectionMeta = SECTIONS.find((s) => s.slug === section);

if (!sectionMeta) {
	return Astro.redirect("/");
}

const entries = await listSection(sectionMeta.prefix);
const tree = buildTree(entries, sectionMeta.slug);
const pinned = await getPinnedFolders(sectionMeta.slug);
const pinnedPathsSet = getPinnedPaths(sectionMeta.prefix);
---

<Layout title={sectionMeta.label} description={`${sectionMeta.label} — ${entries.length} notes`} width="lg">
	<Container size="lg">
		<div class="animate mb-10">
			<BackToPrevious href="/">Back to home</BackToPrevious>
		</div>

		<div class="animate">
			<h1 class="text-2xl font-semibold text-black dark:text-white">
				{sectionMeta.label}
			</h1>
			<p class="mt-1 text-sm text-black/50 dark:text-white/50">
				{entries.length} notes
			</p>
		</div>

		{pinned.length > 0 && (
			<div class="mt-6 animate">
				<h2 class="mb-2 text-xs font-medium uppercase tracking-wider text-black/40 dark:text-white/40">
					Pinned
				</h2>
				<div class="grid grid-cols-1 gap-2 sm:grid-cols-2">
					{pinned.map((p) => (
						<div class="group/pin relative flex items-start gap-3 rounded-sm border border-black/15 p-3 transition-colors duration-300 hover:bg-black/5 dark:border-white/20 dark:hover:bg-white/5">
							<a
								href={p.href}
								class="flex flex-1 items-start gap-3 no-underline min-w-0"
							>
								<span class="mt-0.5 text-base leading-none">📌</span>
								<div class="min-w-0 flex-1">
									<div class="font-medium text-black dark:text-white group-hover/pin:underline underline-offset-4 decoration-black/30 dark:decoration-white/30 truncate">
										{p.label}
									</div>
									<div class="text-xs text-black/40 dark:text-white/40">
										{p.noteCount} notes
									</div>
								</div>
							</a>
							<button
								class="pinned-unpin shrink-0 p-1 rounded opacity-0 group-hover/pin:opacity-100 text-black/20 hover:text-black/50 dark:text-white/20 dark:hover:text-white/50 transition-all"
								data-section={sectionMeta.slug}
								data-folder={p.folderPath}
								data-label={p.label}
								title="Unpin folder"
							>
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M18 6 6 18" /><path d="m6 6 12 12" />
								</svg>
							</button>
						</div>
					))}
				</div>
			</div>
		)}

		<div class="mt-8 animate">
			{entries.length === 0 ? (
				<p class="text-black/50 dark:text-white/50">No notes in this section yet.</p>
			) : (
				<nav class="space-y-1">
					<ul class="space-y-1">
						{tree.map((node) => (
							<SidebarItem node={node} depth={0} sectionSlug={sectionMeta.slug} pinnedPaths={pinnedPathsSet} />
						))}
					</ul>
				</nav>
			)}
		</div>
	</Container>
</Layout>

<script>
	import { initPinToggle, initPinnedUnpin } from "../../lib/pin-toggle";
	initPinToggle();
	initPinnedUnpin();
</script>
