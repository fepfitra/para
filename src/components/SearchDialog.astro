---

---

<div id="search-overlay" class="fixed inset-0 z-[200] hidden">
  <!-- Backdrop -->
  <div id="search-backdrop" class="absolute inset-0 bg-black/50 backdrop-blur-xs"></div>

  <!-- Dialog -->
  <div class="relative mx-auto mt-[15vh] w-full max-w-lg px-4">
    <div class="overflow-hidden rounded-md border border-black/15 bg-neutral-100 shadow-2xl dark:border-white/20 dark:bg-neutral-900">
      <!-- Search input -->
      <div class="flex items-center border-b border-black/10 px-4 dark:border-white/10">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="shrink-0 text-black/40 dark:text-white/40"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          id="search-input"
          type="text"
          placeholder="Search notes..."
          autocomplete="off"
          class="w-full bg-transparent py-3 pl-3 pr-2 text-sm text-black outline-none placeholder:text-black/40 dark:text-white dark:placeholder:text-white/40"
        />
        <kbd class="shrink-0 rounded border border-black/15 px-1.5 py-0.5 text-[10px] text-black/40 dark:border-white/20 dark:text-white/40">ESC</kbd>
      </div>

      <!-- Results -->
      <div id="search-results" class="max-h-[50vh] overflow-y-auto">
        <div id="search-empty" class="px-4 py-8 text-center text-sm text-black/40 dark:text-white/40">
          Type to search across all notes
        </div>
        <ul id="search-list" class="hidden divide-y divide-black/5 dark:divide-white/5"></ul>
      </div>
    </div>
  </div>
</div>

<script is:inline>
(function() {
  let debounceTimer = null;
  let activeIndex = -1;

  function openSearch() {
    const overlay = document.getElementById("search-overlay");
    const input = document.getElementById("search-input");
    if (!overlay || !input) return;
    overlay.classList.remove("hidden");
    input.value = "";
    resetResults();
    setTimeout(() => input.focus(), 50);
    document.body.style.overflow = "hidden";
  }

  function closeSearch() {
    const overlay = document.getElementById("search-overlay");
    if (!overlay) return;
    overlay.classList.add("hidden");
    document.body.style.overflow = "";
    activeIndex = -1;
  }

  function resetResults() {
    const list = document.getElementById("search-list");
    const empty = document.getElementById("search-empty");
    if (list) { list.innerHTML = ""; list.classList.add("hidden"); }
    if (empty) { empty.textContent = "Type to search across all notes"; empty.classList.remove("hidden"); }
    activeIndex = -1;
  }

  function renderResults(results) {
    const list = document.getElementById("search-list");
    const empty = document.getElementById("search-empty");
    if (!list || !empty) return;

    activeIndex = -1;

    if (results.length === 0) {
      list.innerHTML = "";
      list.classList.add("hidden");
      empty.textContent = "No results found";
      empty.classList.remove("hidden");
      return;
    }

    empty.classList.add("hidden");
    list.classList.remove("hidden");
    list.innerHTML = results.map((r, i) =>
      `<li>
        <a href="${r.slug}" data-idx="${i}"
          class="search-result flex flex-col gap-0.5 px-4 py-3 no-underline transition-colors hover:bg-black/5 dark:hover:bg-white/5">
          <span class="text-sm font-medium text-black dark:text-white">${escapeHtml(r.title)}</span>
          <span class="text-xs text-black/40 dark:text-white/40">${escapeHtml(r.section)} / ${escapeHtml(r.path)}</span>
        </a>
      </li>`
    ).join("");
  }

  function setActive(index) {
    const items = document.querySelectorAll("#search-list .search-result");
    items.forEach(el => el.classList.remove("bg-black/5", "dark:bg-white/5"));
    if (index >= 0 && index < items.length) {
      activeIndex = index;
      items[index].classList.add("bg-black/5", "dark:bg-white/5");
      items[index].scrollIntoView({ block: "nearest" });
    }
  }

  function escapeHtml(str) {
    return str.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;").replace(/"/g, "&quot;");
  }

  async function doSearch(query) {
    if (!query.trim()) { resetResults(); return; }
    try {
      const res = await fetch(`/api/search?q=${encodeURIComponent(query)}`);
      const data = await res.json();
      renderResults(data);
    } catch {
      const empty = document.getElementById("search-empty");
      if (empty) { empty.textContent = "Search failed"; empty.classList.remove("hidden"); }
    }
  }

  // Global keyboard shortcut
  document.addEventListener("keydown", (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === "k") {
      e.preventDefault();
      const overlay = document.getElementById("search-overlay");
      if (overlay?.classList.contains("hidden")) {
        openSearch();
      } else {
        closeSearch();
      }
    }
    if (e.key === "Escape") closeSearch();
  });

  // Wait for DOM
  document.addEventListener("DOMContentLoaded", () => {
    const overlay = document.getElementById("search-overlay");
    const backdrop = document.getElementById("search-backdrop");
    const input = document.getElementById("search-input");

    // Open button
    document.getElementById("search-trigger")?.addEventListener("click", openSearch);

    // Close on backdrop click
    backdrop?.addEventListener("click", closeSearch);

    // Input handler with debounce
    input?.addEventListener("input", () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => doSearch(input.value), 200);
    });

    // Keyboard navigation within results
    input?.addEventListener("keydown", (e) => {
      const items = document.querySelectorAll("#search-list .search-result");
      if (e.key === "ArrowDown") {
        e.preventDefault();
        setActive(Math.min(activeIndex + 1, items.length - 1));
      } else if (e.key === "ArrowUp") {
        e.preventDefault();
        setActive(Math.max(activeIndex - 1, 0));
      } else if (e.key === "Enter" && activeIndex >= 0 && items[activeIndex]) {
        e.preventDefault();
        items[activeIndex].click();
      }
    });
  });
})();
</script>
