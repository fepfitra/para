---
import Container from "./Container.astro";
import { PARA_SECTIONS } from "../lib/s3";

type Props = {
  containerSize?: "sm" | "md" | "lg" | "xl" | "2xl";
};

const { containerSize = "sm" } = Astro.props;
const pathname = Astro.url.pathname;
---

<header>
  <Container size={containerSize}>
    <div class="flex flex-wrap justify-between gap-y-2">
      <a href="/" class="font-semibold text-current no-underline hover:text-black dark:hover:text-white transition-colors duration-300">
        PARA
      </a>
      <nav class="flex items-center gap-4 text-sm">
        {PARA_SECTIONS.map((s, i) => (
          <Fragment>
            {i > 0 && <span>/</span>}
            <a
              href={`/${s.slug}`}
              class:list={[
                "no-underline transition-colors duration-300 ease-in-out",
                pathname.startsWith(`/${s.slug}`)
                  ? "text-black dark:text-white font-medium"
                  : "text-current underline underline-offset-[3px] decoration-black/30 dark:decoration-white/30 hover:text-black hover:decoration-black/50 dark:hover:text-white dark:hover:decoration-white/50",
              ]}
            >
              {s.label.toLowerCase()}
            </a>
          </Fragment>
        ))}
      </nav>
    </div>
  </Container>
</header>
