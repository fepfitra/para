---
import SidebarItem from "./SidebarItem.astro";
import type { SidebarNode, PinnedFolder } from "../lib/s3";

interface Props {
	nodes: SidebarNode[];
	currentPath?: string;
	sectionLabel: string;
	sectionSlug: string;
	pinnedFolders?: PinnedFolder[];
}

const { nodes, currentPath, sectionLabel, sectionSlug, pinnedFolders = [] } = Astro.props;
---

<aside class="w-full pr-4 md:flex-shrink-0 md:border-r md:border-black/10 dark:md:border-white/10">
	<button
		id="sidebar-toggle"
		class="mb-4 flex items-center gap-2 text-lg font-semibold md:hidden"
		aria-expanded="false"
		aria-controls="sidebar-content"
	>
		<svg
			xmlns="http://www.w3.org/2000/svg"
			width="24"
			height="24"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
		>
			<line x1="4" x2="20" y1="12" y2="12"></line>
			<line x1="4" x2="20" y1="6" y2="6"></line>
			<line x1="4" x2="20" y1="18" y2="18"></line>
		</svg>
		Menu
	</button>

	<div id="sidebar-content" class="hidden md:block pb-8">
		<div class="mb-4 text-lg font-semibold">
			<a
				href={`/${sectionSlug}`}
				class:list={[
					"hover:text-black dark:hover:text-white transition-colors no-underline",
					"text-black/70 dark:text-white/70",
				]}
			>
				{sectionLabel}
			</a>
		</div>

		{pinnedFolders.length > 0 && (
			<div class="mb-4">
				<div class="mb-1.5 px-3 text-xs font-medium uppercase tracking-wider text-black/40 dark:text-white/40">
					Pinned
				</div>
				<ul class="space-y-0.5">
					{pinnedFolders.map((p) => (
						<li>
							<a
								href={p.href}
								class="flex items-center gap-2 rounded-md px-3 py-1.5 text-sm font-medium text-black/70 transition-colors hover:bg-black/5 hover:text-black dark:text-white/70 dark:hover:bg-white/5 dark:hover:text-white no-underline"
							>
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-black/30 dark:text-white/30">
									<path d="M12 17v5" /><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z" />
								</svg>
								<span class="truncate">{p.label}</span>
								<span class="ml-auto text-xs text-black/30 dark:text-white/30">{p.noteCount}</span>
							</a>
						</li>
					))}
				</ul>
				<div class="mt-3 border-b border-black/10 dark:border-white/10"></div>
			</div>
		)}

		<nav class="space-y-1">
			<ul class="space-y-1">
				{nodes.map((node) => (
					<SidebarItem node={node} currentPath={currentPath} depth={0} />
				))}
			</ul>
		</nav>
	</div>
</aside>

<script>
	const toggleButton = document.getElementById("sidebar-toggle");
	const sidebarContent = document.getElementById("sidebar-content");

	if (toggleButton && sidebarContent) {
		toggleButton.addEventListener("click", () => {
			const isExpanded = toggleButton.getAttribute("aria-expanded") === "true";
			toggleButton.setAttribute("aria-expanded", (!isExpanded).toString());
			sidebarContent.classList.toggle("hidden");
		});
	}
</script>
