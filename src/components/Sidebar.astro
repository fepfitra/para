---
import SidebarItem from "./SidebarItem.astro";
import type { SidebarNode, PinnedFolder } from "../lib/s3";

interface Props {
	nodes: SidebarNode[];
	currentPath?: string;
	sectionLabel: string;
	sectionSlug: string;
	pinnedFolders?: PinnedFolder[];
	pinnedPaths?: Set<string>;
}

const { nodes, currentPath, sectionLabel, sectionSlug, pinnedFolders = [], pinnedPaths } = Astro.props;
---

<aside class="w-full lg:flex-shrink-0">
	<div id="sidebar-content" class="pb-8">
		<div class="mt-6 mb-4 text-lg font-semibold">
			<a
				href={`/${sectionSlug}`}
				class:list={[
					"hover:text-black dark:hover:text-white transition-colors no-underline",
					"text-black/70 dark:text-white/70",
				]}
			>
				{sectionLabel}
			</a>
		</div>

		<div id="sidebar-pinned-section">
			{pinnedFolders.length > 0 && (
				<div class="mb-4">
					<div class="mb-1.5 px-3 text-xs font-medium uppercase tracking-wider text-black/40 dark:text-white/40">
						Pinned
					</div>
					<ul class="space-y-0.5" id="sidebar-pinned-list">
						{pinnedFolders.map((p) => (
							<li data-pinned-folder={p.folderPath} class="group/pin flex items-center">
								<a
									href={p.href}
									class="flex flex-1 items-center gap-2 rounded-md px-3 py-1.5 text-sm font-medium text-black/70 transition-colors hover:bg-black/5 hover:text-black dark:text-white/70 dark:hover:bg-white/5 dark:hover:text-white no-underline min-w-0"
								>
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-black/30 dark:text-white/30">
										<path d="M12 17v5" /><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z" />
									</svg>
									<span class="truncate">{p.label}</span>
									<span class="ml-auto text-xs text-black/30 dark:text-white/30">{p.noteCount}</span>
								</a>
								<button
									class="pinned-unpin shrink-0 p-1 rounded opacity-0 group-hover/pin:opacity-100 text-black/20 hover:text-black/50 dark:text-white/20 dark:hover:text-white/50 transition-all"
									data-section={sectionSlug}
									data-folder={p.folderPath}
									data-label={p.label}
									title="Unpin folder"
								>
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M18 6 6 18" /><path d="m6 6 12 12" />
									</svg>
								</button>
							</li>
						))}
					</ul>
					<div class="mt-3 border-b border-black/10 dark:border-white/10"></div>
				</div>
			)}
		</div>

		<nav class="space-y-1">
			<ul class="space-y-1">
				{nodes.map((node) => (
					<SidebarItem
						node={node}
						currentPath={currentPath}
						depth={0}
						sectionSlug={sectionSlug}
						pinnedPaths={pinnedPaths}
					/>
				))}
			</ul>
		</nav>
	</div>
</aside>

<script>
	import { initPinToggle, initPinnedUnpin } from "../lib/pin-toggle";

	initPinToggle();
	initPinnedUnpin();
</script>