---
import type { SidebarNode } from "../lib/s3";

interface Props {
	node: SidebarNode;
	currentPath?: string;
	depth?: number;
}

const { node, currentPath, depth = 0 } = Astro.props;

const isActive = node.slug === currentPath;
const hasChildren = node.children.length > 0;

function containsPath(n: SidebarNode, path: string | undefined): boolean {
	if (!path) return false;
	if (n.slug === path) return true;
	return n.children.some((c) => containsPath(c, path));
}

const isAncestor = !node.slug && containsPath(node, currentPath);
---

<li>
	{hasChildren && !node.slug ? (
		<details
			open={isAncestor || depth === 0}
			class="group"
		>
			<summary class="cursor-pointer list-none [&::-webkit-details-marker]:hidden">
				<div class="flex items-center justify-between rounded-md transition-colors hover:bg-black/5 dark:hover:bg-white/5">
					<div
						class="flex-1 px-3 py-2 text-sm font-semibold text-black/50 dark:text-white/50"
						style={`padding-left: ${depth * 1 + 0.75}rem`}
					>
						{node.label}
					</div>
					<div class="pr-2 text-black/30 transition-transform duration-200 group-open:rotate-90 dark:text-white/30">
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="m9 18 6-6-6-6" />
						</svg>
					</div>
				</div>
			</summary>
			<ul class="mt-1 space-y-1">
				{node.children.map((child) => (
					<Astro.self node={child} currentPath={currentPath} depth={depth + 1} />
				))}
			</ul>
		</details>
	) : node.slug ? (
		<a
			href={node.slug}
			class:list={[
				"block rounded-md px-3 py-2 text-sm font-medium transition-colors",
				isActive
					? "bg-black/5 text-black dark:bg-white/10 dark:text-white"
					: "text-black/70 hover:bg-black/5 hover:text-black dark:text-white/70 dark:hover:bg-white/5 dark:hover:text-white",
			]}
			style={`padding-left: ${depth * 1 + 0.75}rem`}
		>
			{node.label}
		</a>
	) : (
		<div
			class="px-3 py-2 text-sm font-semibold text-black/50 dark:text-white/50"
			style={`padding-left: ${depth * 1 + 0.75}rem`}
		>
			{node.label}
		</div>
	)}
</li>
