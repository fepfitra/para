---
import type { SidebarNode } from "../lib/s3";

interface Props {
	node: SidebarNode;
	currentPath?: string;
	depth?: number;
	sectionSlug?: string;
	/** Accumulated folder path segments from parent, e.g. "english" or "sub/folder" */
	parentPath?: string;
	/** Set of folder paths that are currently pinned */
	pinnedPaths?: Set<string>;
}

const { node, currentPath, depth = 0, sectionSlug, parentPath = "", pinnedPaths } = Astro.props;

const isActive = node.slug === currentPath;
const hasChildren = node.children.length > 0;
const isFolder = hasChildren && !node.slug;

// Build the folder path for this node (only meaningful for folders)
const folderPath = isFolder
	? (parentPath ? `${parentPath}/${node.label}` : node.label)
	: parentPath;

const isPinned = isFolder && pinnedPaths?.has(folderPath);

function containsPath(n: SidebarNode, path: string | undefined): boolean {
	if (!path) return false;
	if (n.slug === path) return true;
	return n.children.some((c) => containsPath(c, path));
}

const isAncestor = isFolder && containsPath(node, currentPath);
---

<li>
	{isFolder ? (
		<details
			open={isAncestor}
			class="group"
		>
			<summary class="cursor-pointer list-none [&::-webkit-details-marker]:hidden">
				<div class="flex items-center justify-between rounded-md transition-colors hover:bg-black/5 dark:hover:bg-white/5">
					<div
						class="flex-1 px-3 py-2 text-sm font-semibold text-black/50 dark:text-white/50"
						style={`padding-left: ${depth * 1 + 0.75}rem`}
					>
						{node.label}
					</div>
					<div class="flex items-center gap-0.5 pr-1">
						{sectionSlug && (
							<button
								class="pin-toggle p-1 rounded text-black/20 hover:text-black/50 dark:text-white/20 dark:hover:text-white/50 transition-colors"
								data-section={sectionSlug}
								data-folder={folderPath}
								data-pinned={isPinned ? "true" : "false"}
								title={isPinned ? "Unpin folder" : "Pin folder"}
							>
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill={isPinned ? "currentColor" : "none"} stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="pin-icon">
									<path d="M12 17v5" /><path d="M9 10.76a2 2 0 0 1-1.11 1.79l-1.78.9A2 2 0 0 0 5 15.24V16a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-.76a2 2 0 0 0-1.11-1.79l-1.78-.9A2 2 0 0 1 15 10.76V7a1 1 0 0 1 1-1 2 2 0 0 0 0-4H8a2 2 0 0 0 0 4 1 1 0 0 1 1 1z" />
								</svg>
							</button>
						)}
						<div class="text-black/30 transition-transform duration-200 group-open:rotate-90 dark:text-white/30">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="m9 18 6-6-6-6" />
							</svg>
						</div>
					</div>
				</div>
			</summary>
			<ul class="mt-1 space-y-1">
				{node.children.map((child) => (
					<Astro.self
						node={child}
						currentPath={currentPath}
						depth={depth + 1}
						sectionSlug={sectionSlug}
						parentPath={folderPath}
						pinnedPaths={pinnedPaths}
					/>
				))}
			</ul>
		</details>
	) : node.slug ? (
		<a
			href={node.slug}
			class:list={[
				"block rounded-md px-3 py-2 text-sm font-medium transition-colors",
				isActive
					? "bg-black/5 text-black dark:bg-white/10 dark:text-white"
					: "text-black/70 hover:bg-black/5 hover:text-black dark:text-white/70 dark:hover:bg-white/5 dark:hover:text-white",
			]}
			style={`padding-left: ${depth * 1 + 0.75}rem`}
		>
			{node.label}
		</a>
	) : (
		<div
			class="px-3 py-2 text-sm font-semibold text-black/50 dark:text-white/50"
			style={`padding-left: ${depth * 1 + 0.75}rem`}
		>
			{node.label}
		</div>
	)}
</li>
