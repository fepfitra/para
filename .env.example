# S3 Configuration (required)
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=my-bucket
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1

# Sections (required)
# Format: "prefix/slug/label,prefix/slug/label"
# Each section needs: folder name in S3 / URL slug / display label
#
# Examples:
# 
# Simple 2-folder structure:
SECTIONS="Work/work/Work,Personal/personal/Personal"
#
# PARA method:
# SECTIONS="1. Projects/projects/Projects,2. Areas/areas/Areas,3. Resources/resources/Resources,4. Archives/archives/Archives"
#
# Custom naming:
# SECTIONS="01-Active/active/Active,99-Archive/archive/Archive"

# Tasks Configuration (optional - if not set, tasks feature is hidden)
# TASKS_PREFIX="TaskNotes/Tasks/"                    # S3 prefix for task files (required to enable tasks)
# TASK_TAGS="task"                                   # Required tags (comma-separated, ALL must match)
# TASK_EXCLUDED_TAGS="archived"                      # Excluded tags (comma-separated, ANY excludes)
# TASK_EXCLUDED_STATUSES="done"                      # Excluded statuses (comma-separated)
